NODE_ENV=development
PORT=5000

# MongoDB Atlas connection string, database name: mora-on-the-hunt
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.eu8dehj.mongodb.net/mora-on-the-hunt?appName=Cluster0
# Comma-separated list of allowed CORS origins (frontend URL(s))
CLIENT_URL=http://localhost:5173

# JWT
JWT_SECRET=replace-with-a-long-random-string
JWT_EXPIRES_IN=1d
JWT_REMEMBER_ME_EXPIRES_IN=30d

# Uploads
MAX_UPLOAD_SIZE_MB=50

# AWS S3 (payment slip storage) — bucket must be private, never public
AWS_REGION=ap-southeast-2
AWS_ACCESS_KEY_ID=replace-with-iam-user-access-key-id
AWS_SECRET_ACCESS_KEY=replace-with-iam-user-secret-access-key
AWS_S3_BUCKET=mora-on-the-hunt-payment-slips

# First superadmin bootstrap (used only by `npm run seed`)
SEED_ADMIN_NAME=Super Admin
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=change-this-password
